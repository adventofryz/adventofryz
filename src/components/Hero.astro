---
---

<section id="hero">
  <div class="grid-bg"></div>
  <div class="container">
    <h1>
      <span class="eyebrow">Software Engineer</span>
      I build systems that make complex data simple.
    </h1>
  </div>
</section>

<style>
  #hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    animation: fade-rise 400ms ease-out both;
  }

  .grid-bg {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(circle at 15% 30%, black, transparent 65%);
    pointer-events: none;
  }

  h1 {
    position: relative;
    max-width: 30ch;
    font-size: clamp(2.25rem, 5vw, 4rem);
    line-height: 1.15;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .eyebrow {
    display: block;
    font-size: 0.4em;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.5rem;
  }

  @keyframes fade-rise {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #hero {
      animation: none;
    }
  }
</style>
