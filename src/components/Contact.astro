<style>
  #contact {
    padding: 4rem 0 5rem;
    border-top: 1px solid var(--border);
  }

  h2 {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0 0 1.5rem;
  }

  ul {
    display: flex;
    gap: 2rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--text-muted);
    transition: color 150ms ease;
  }

  a:hover,
  a:focus-visible {
    color: var(--accent);
  }
</style>
