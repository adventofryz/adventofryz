---
// PLACEHOLDER: replace with the real MapLibre + deck.gl implementation using real GPS
// trace data (Cabspotting SF or Rome taxi dataset). See PLAN.md.
---

<div class="fleet-demo" id="fleet-demo">
  <div class="stats">
    <div class="stat">
      <span class="stat-value">5,000</span>
      <span class="stat-label">Total</span>
    </div>
    <div class="stat">
      <span class="stat-value moving">4,250</span>
      <span class="stat-label">Moving</span>
    </div>
    <div class="stat">
      <span class="stat-value idle">750</span>
      <span class="stat-label">Idle</span>
    </div>
  </div>

  <div class="map">
    <span class="demo-label">Live demo</span>

    <svg id="fleet-svg" viewBox="0 0 680 420" preserveAspectRatio="xMidYMid meet"></svg>

    <div class="legend">
      <span><i class="dot moving"></i>Moving</span>
      <span><i class="dot idle"></i>Idle</span>
    </div>

    <div class="popover">
      <p class="popover-title">VH-2891</p>
      <p><span>Speed</span><span>34 mph</span></p>
      <p><span>Heading</span><span>128&deg;</span></p>
    </div>
  </div>
</div>

<style>
  .fleet-demo {
    border-bottom: 1px solid var(--border);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 500ms ease-out, transform 500ms ease-out;
  }

  .fleet-demo.in-view {
    opacity: 1;
    transform: translateY(0);
  }

  .stats {
    display: flex;
    gap: 2rem;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .stat-value {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 600;
  }

  .stat-value.moving {
    color: var(--accent);
  }

  .stat-value.idle {
    color: var(--text-muted);
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .map {
    position: relative;
    width: 100%;
    aspect-ratio: 680 / 420;
    background-color: var(--bg);
    background-image: linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 170px 140px;
    overflow: hidden;
  }

  svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  :global(.marker) {
    stroke: none;
  }

  :global(.marker.moving) {
    fill: var(--accent);
  }

  :global(.marker.idle) {
    fill: var(--text-muted);
  }

  .demo-label {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
  }

  .legend {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    display: flex;
    gap: 0.75rem;
    font-size: 0.7rem;
    color: var(--text-muted);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
  }

  .legend span {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    display: inline-block;
  }

  .dot.moving {
    background: var(--accent);
  }

  .dot.idle {
    background: var(--text-muted);
  }

  .popover {
    position: absolute;
    bottom: 0.75rem;
    left: 0.75rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.6rem 0.8rem;
    font-size: 0.75rem;
    min-width: 9rem;
  }

  .popover-title {
    margin: 0 0 0.35rem;
    font-family: var(--font-mono);
    color: var(--text);
    font-weight: 600;
  }

  .popover p {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin: 0.15rem 0;
    color: var(--text-muted);
  }

  .popover p span:last-child {
    font-family: var(--font-mono);
    color: var(--text);
  }
</style>

<script>
  const svgNS = 'http://www.w3.org/2000/svg';
  const svg = document.getElementById('fleet-svg');
  const root = document.getElementById('fleet-demo');

  if (svg && root) {
    const WIDTH = 680;
    const HEIGHT = 420;
    const MARGIN = 8;
    const COUNT = 130;
    const IDLE_RATIO = 0.15;

    const vehicles = Array.from({ length: COUNT }, () => {
      const angle = Math.random() * Math.PI * 2;
      const moving = Math.random() > IDLE_RATIO;
      const speed = moving ? 10 + Math.random() * 18 : 0;

      const marker = document.createElementNS(svgNS, 'polygon');
      marker.setAttribute('points', '0,-5 4,5 -4,5');
      marker.setAttribute('class', moving ? 'marker moving' : 'marker idle');
      svg.appendChild(marker);

      return {
        x: MARGIN + Math.random() * (WIDTH - MARGIN * 2),
        y: MARGIN + Math.random() * (HEIGHT - MARGIN * 2),
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed,
        headingDeg: (angle * 180) / Math.PI + 90,
        moving,
        el: marker,
      };
    });

    function draw() {
      for (const v of vehicles) {
        v.el.setAttribute('transform', `translate(${v.x} ${v.y}) rotate(${v.headingDeg})`);
      }
    }

    draw();

    let lastTime = null;
    let running = false;

    function tick(time) {
      if (!running) return;
      if (lastTime === null) lastTime = time;
      const dt = (time - lastTime) / 1000;
      lastTime = time;

      for (const v of vehicles) {
        if (!v.moving) continue;

        v.x += v.vx * dt;
        v.y += v.vy * dt;

        if (v.x < MARGIN || v.x > WIDTH - MARGIN) {
          v.vx *= -1;
          v.x = Math.min(Math.max(v.x, MARGIN), WIDTH - MARGIN);
        }
        if (v.y < MARGIN || v.y > HEIGHT - MARGIN) {
          v.vy *= -1;
          v.y = Math.min(Math.max(v.y, MARGIN), HEIGHT - MARGIN);
        }

        v.headingDeg = (Math.atan2(v.vy, v.vx) * 180) / Math.PI + 90;
      }

      draw();
      requestAnimationFrame(tick);
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            if (!running) {
              running = true;
              requestAnimationFrame(tick);
            }
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.3 },
    );

    observer.observe(root);
  }
</script>
