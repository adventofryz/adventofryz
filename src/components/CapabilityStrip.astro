---
const capabilities = [
  'React/TypeScript',
  'Node.js',
  'PostgreSQL',
  'MapLibre',
  'deck.gl',
  'Azure',
];
---

<section id="about">
  <div class="container">
    <h2>Toolkit</h2>
    <ul>
      {capabilities.map((capability) => <li>{capability}</li>)}
    </ul>
  </div>
</section>

<style>
  #about {
    padding: 4rem 0;
    border-top: 1px solid var(--border);
  }

  h2 {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0 0 1.5rem;
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 2rem;
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 1.05rem;
  }
</style>
